# Gemini (required for chat tools + streaming)
# https://aistudio.google.com/ or Google AI Studio
GEMINI_API_KEY=your_gemini_api_key

# Google Maps Platform — Maps JavaScript / Places (booth finder)
# https://console.cloud.google.com/google/maps-apis
MAPS_API_KEY=your_maps_api_key

# Cloud Translation API (optional — enables translate_text tool)
# Restrict key to Translation API; same project as other GCP APIs is fine.
TRANSLATION_API_KEY=
# Alias supported by code:
# GOOGLE_TRANSLATION_API_KEY=

# Cloud Natural Language API (optional — enables analyze_voter_query tool)
NATURAL_LANGUAGE_API_KEY=
# Alias:
# CLOUD_NL_API_KEY=

# Server
PORT=3000

# Auth (use a long random string in production; store in Secret Manager on Cloud Run)
JWT_SECRET=change_me_in_production

# Firebase Admin (optional — only if using Firestore-backed features)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# reCAPTCHA v3 (optional)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Cloud Run / Docker: listen on 8080 (set PORT=8080 in service config)
