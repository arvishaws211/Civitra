{
  "name": "civitra",
  "version": "1.0.0",
  "description": "Civic + Mitra = Clarity in Every Vote. AI-powered Election Process Education Assistant.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "validate:ci": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage"
  },
  "keywords": [
    "election",
    "education",
    "ai",
    "gemini",
    "civics",
    "india"
  ],
  "author": "Civitra Team",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.0.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2",
    "@types/multer": "^1.4.12"
  }
}
